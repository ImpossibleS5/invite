---
import { wedding } from '../data/wedding'

const icons = ['bouquet', 'rings', 'glass'] as const
type Icon = typeof icons[number]
---

<section class="program section" id="program">
  <div class="container">
    <p class="program__eyebrow">— расписание —</p>
    <h2 class="section-title">Программа дня</h2>
    <div class="divider">
      <svg viewBox="0 0 60 12" width="56" height="12" aria-hidden="true">
        <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
          <path d="M30 1 L30 11"/>
          <path d="M30 4 C 24 2 18 2 12 5"/>
          <path d="M30 4 C 36 2 42 2 48 5"/>
        </g>
        <ellipse cx="14" cy="5.5" rx="3" ry="1" transform="rotate(-30 14 5.5)" fill="currentColor"/>
        <ellipse cx="46" cy="5.5" rx="3" ry="1" transform="rotate(30 46 5.5)" fill="currentColor"/>
        <circle cx="30" cy="11" r="1.2" fill="currentColor"/>
      </svg>
    </div>

    <ol class="timeline" id="program-timeline">
      {wedding.program.map((item, i) => {
        const icon: Icon = (icons[i] ?? 'bouquet') as Icon
        return (
          <li class="timeline__item" data-stagger={i}>
            <div class="timeline__stamp" aria-hidden="true">
              {icon === 'bouquet' && (
                <svg viewBox="0 0 40 40">
                  <g stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round">
                    <path d="M20 36 L20 22"/>
                    <path d="M20 24 L13 30"/>
                    <path d="M20 24 L27 30"/>
                  </g>
                  <circle cx="14" cy="14" r="4.5" fill="currentColor" opacity="0.85"/>
                  <circle cx="22" cy="10" r="5" fill="currentColor"/>
                  <circle cx="28" cy="16" r="4" fill="currentColor" opacity="0.85"/>
                  <circle cx="18" cy="18" r="3.5" fill="currentColor" opacity="0.7"/>
                </svg>
              )}
              {icon === 'rings' && (
                <svg viewBox="0 0 40 40">
                  <g stroke="currentColor" stroke-width="1.6" fill="none">
                    <circle cx="15" cy="22" r="9"/>
                    <circle cx="25" cy="22" r="9"/>
                  </g>
                  <circle cx="20" cy="22" r="1.6" fill="currentColor"/>
                  <path d="M14 8 L16 12 L18 8 Z" fill="currentColor" opacity="0.7"/>
                  <path d="M22 8 L24 12 L26 8 Z" fill="currentColor" opacity="0.7"/>
                </svg>
              )}
              {icon === 'glass' && (
                <svg viewBox="0 0 40 40">
                  <g stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 8 L26 8 L24 22 C 24 24, 22 26, 20 26 C 18 26, 16 24, 16 22 Z"/>
                    <path d="M20 26 L20 32"/>
                    <path d="M16 32 L24 32"/>
                  </g>
                  <path d="M14 8 L26 8 L25 14 L15 14 Z" fill="currentColor" opacity="0.4"/>
                </svg>
              )}
            </div>
            <div class="timeline__body">
              <div class="timeline__time">{item.time}</div>
              <div class="timeline__title">{item.title}</div>
              <div class="timeline__place">{item.place}</div>
            </div>
          </li>
        )
      })}
    </ol>
  </div>
</section>

<style>
  .program { text-align: left; }
  .program .section-title,
  .program .divider,
  .program__eyebrow { text-align: center; }
  .program .divider { margin-bottom: 56px; }

  .program__eyebrow {
    font-family: var(--font-engraved);
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--accent-gold);
    text-align: center;
    margin: 0 0 14px;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 440px;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 36px;
    top: 36px;
    bottom: 36px;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--accent-gold) 8%, var(--accent-gold) 92%, transparent);
    opacity: 0.55;
  }

  /* Items: staggered scroll-triggered fade-in. Initial state hidden. */
  .timeline__item {
    display: flex;
    gap: 28px;
    padding: 22px 0;
    position: relative;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms var(--ease-out),
      transform 700ms var(--ease-out);
  }
  .timeline__item.is-revealed {
    opacity: 1;
    transform: none;
  }
  /* Stagger delays (~120ms per item) take effect once .is-revealed is added */
  .timeline__item[data-stagger='0'] { transition-delay: 0ms; }
  .timeline__item[data-stagger='1'] { transition-delay: 140ms; }
  .timeline__item[data-stagger='2'] { transition-delay: 280ms; }
  .timeline__item[data-stagger='3'] { transition-delay: 420ms; }

  .timeline__stamp {
    flex: 0 0 72px;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FFFFFF, #FBF4E8);
    border: 1px solid var(--accent-gold);
    box-shadow: var(--shadow-soft), inset 0 0 0 4px rgba(255, 255, 255, 0.7);
    color: var(--accent-gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: transform 240ms var(--ease-out), box-shadow 240ms var(--ease-out);
  }
  .timeline__stamp svg { width: 36px; height: 36px; }
  @media (hover: hover) and (pointer: fine) {
    .timeline__item:hover .timeline__stamp {
      transform: scale(1.06) rotate(-2deg);
      box-shadow: var(--shadow-card), inset 0 0 0 4px rgba(255, 255, 255, 0.9);
    }
  }

  .timeline__body {
    padding-top: 8px;
    flex: 1 1 auto;
  }
  .timeline__time {
    font-family: var(--font-engraved);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-gold-deep);
    margin-bottom: 6px;
    line-height: 1;
    letter-spacing: 0.02em;
  }
  .timeline__title {
    font-family: var(--font-engraved);
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-primary);
    text-transform: uppercase;
    letter-spacing: 0.26em;
    margin-bottom: 8px;
  }
  .timeline__place {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-secondary);
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .timeline__stamp { flex-basis: 84px; width: 84px; height: 84px; }
    .timeline__stamp svg { width: 42px; height: 42px; }
    .timeline::before { left: 42px; }
    .timeline__time { font-size: 36px; }
    .timeline__title { font-size: 13px; }
    .timeline__place { font-size: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline__item {
      opacity: 1;
      transform: none;
      transition-delay: 0ms !important;
    }
  }
</style>

<script>
  // Reveal each timeline item only when it scrolls into view.
  // Combined with CSS transition-delays, this produces a staggered cascade
  // when the user reaches the program section.
  const items = document.querySelectorAll<HTMLElement>('#program-timeline .timeline__item')
  if (items.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed')
            observer.unobserve(entry.target)
          }
        }
      },
      { threshold: 0.25, rootMargin: '0px 0px -10% 0px' }
    )
    items.forEach((el) => observer.observe(el))
  } else {
    // No IO support — show immediately
    items.forEach((el) => el.classList.add('is-revealed'))
  }
</script>
