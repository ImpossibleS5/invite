---
import { wedding } from '../data/wedding'
---

<section class="dresscode section" id="dresscode">
  <div class="container">
    <h2 class="section-title">Дресс-код</h2>
    <div class="divider">
      <svg viewBox="0 0 60 12" width="56" height="12" aria-hidden="true">
        <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
          <path d="M30 1 L30 11"/>
          <path d="M30 4 C 24 2 18 2 12 5"/>
          <path d="M30 4 C 36 2 42 2 48 5"/>
        </g>
        <ellipse cx="14" cy="5.5" rx="3" ry="1" transform="rotate(-30 14 5.5)" fill="currentColor"/>
        <ellipse cx="46" cy="5.5" rx="3" ry="1" transform="rotate(30 46 5.5)" fill="currentColor"/>
        <circle cx="30" cy="11" r="1.2" fill="currentColor"/>
      </svg>
    </div>

    <p class="dresscode__intro">{wedding.dressCode.intro}</p>

    <ul class="palette">
      {wedding.dressCode.palette.map((c, i) => {
        const roman = ['I', 'II', 'III', 'IV', 'V'][i] ?? `${i + 1}`
        return (
          <li class="palette__item">
            <span class="palette__roman" aria-hidden="true">{roman}</span>
            <div class="palette__swatch" style={`background:${c.hex}`}></div>
            <div class="palette__name">{c.name}</div>
            <div class="palette__pantone">PANTONE {c.pantone}</div>
          </li>
        )
      })}
    </ul>

    <p class="dresscode__note">{wedding.dressCode.note}</p>
  </div>
</section>

<style>
  .dresscode { text-align: center; }
  .dresscode__intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-secondary);
    margin: 0 auto 32px;
    max-width: 360px;
    line-height: 1.55;
  }
  .palette {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px 12px;
  }
  .palette__item {
    flex: 0 0 calc(33% - 12px);
    max-width: 110px;
    text-align: center;
  }
  .palette__roman {
    display: block;
    font-family: var(--font-engraved);
    font-size: 12px;
    font-weight: 500;
    color: var(--accent-gold);
    letter-spacing: 0.18em;
    margin-bottom: 8px;
  }
  .palette__swatch {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin: 0 auto 10px;
    box-shadow: var(--shadow-soft), inset 0 0 0 2px rgba(255, 255, 255, 0.6);
    border: 1px solid var(--line-strong);
    transition: transform 220ms var(--ease-out), box-shadow 220ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .palette__item:hover .palette__swatch {
      transform: scale(1.08);
      box-shadow: var(--shadow-card), inset 0 0 0 2px rgba(255, 255, 255, 0.8);
    }
  }
  .palette__name {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 13px;
    color: var(--ink-primary);
    margin-bottom: 3px;
    line-height: 1.3;
  }
  .palette__pantone {
    font-family: var(--font-engraved);
    font-size: 9px;
    font-weight: 500;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
  }
  .dresscode__note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-muted);
    margin: 0;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
