---
import { wedding } from '../data/wedding'
const base = import.meta.env.BASE_URL
const audioSrc = wedding.music.src
  ? wedding.music.src.startsWith('/')
    ? `${base}${wedding.music.src.slice(1)}`
    : wedding.music.src
  : ''
---

<div class="music">
  <audio id="music-audio" loop preload="none" src={audioSrc}></audio>

  <div class="music-prompt" id="music-prompt" hidden>
    <span class="music-prompt__icon">♪</span>
    <span class="music-prompt__text">Включить фоновую музыку?</span>
    <div class="music-prompt__actions">
      <button class="music-prompt__yes" id="music-yes">Да ✨</button>
      <button class="music-prompt__no" id="music-no">Не сейчас</button>
    </div>
  </div>

  <button class="music-toggle" id="music-toggle" aria-label="Включить/выключить музыку" hidden>
    <span id="music-toggle-icon">♪</span>
  </button>

  <div class="music-toast" id="music-toast" hidden></div>
</div>

<style>
  .music-prompt,
  .music-toggle,
  .music-toast {
    position: fixed;
    z-index: 100;
  }
  .music-prompt {
    right: 20px;
    bottom: 20px;
    background: var(--bg-paper);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-card);
    padding: 26px 28px 22px;
    box-shadow: var(--shadow-card);
    max-width: 360px;
    width: calc(100vw - 40px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
    transform-origin: bottom right;
    animation: music-prompt-in 380ms var(--ease-drawer);
  }
  @keyframes music-prompt-in {
    from { opacity: 0; transform: translateY(20px) scale(0.96); filter: blur(4px); }
    to   { opacity: 1; transform: none; filter: blur(0); }
  }
  .music-prompt__icon {
    font-size: 28px;
    color: var(--accent-gold-deep);
    line-height: 1;
  }
  .music-prompt__text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-primary);
    line-height: 1.4;
    margin: 0;
  }
  .music-prompt__actions {
    display: flex;
    gap: 10px;
    margin-top: 6px;
  }
  .music-prompt__yes,
  .music-prompt__no {
    font-family: var(--font-engraved);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    padding: 11px 22px;
    border: 1px solid var(--accent-gold);
    background: transparent;
    color: var(--accent-gold-deep);
    cursor: pointer;
    transition: background 180ms var(--ease-out), color 180ms var(--ease-out), transform 160ms var(--ease-press);
  }
  .music-prompt__yes {
    background: var(--accent-rose);
    color: #fff;
    border-color: var(--accent-rose);
  }
  @media (hover: hover) and (pointer: fine) {
    .music-prompt__yes:hover { background: var(--accent-rose-deep); border-color: var(--accent-rose-deep); }
    .music-prompt__no:hover  { background: rgba(162, 142, 95, 0.10); }
  }
  .music-prompt__yes:active,
  .music-prompt__no:active { transform: scale(0.96); }

  .music-toggle {
    right: 20px;
    bottom: 20px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--bg-paper);
    border: 1px solid var(--line-soft);
    box-shadow: var(--shadow-soft);
    color: var(--accent-gold-deep);
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 220ms var(--ease-out), color 220ms var(--ease-out),
                transform 200ms var(--ease-out), box-shadow 220ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .music-toggle:hover {
      transform: scale(1.06);
      box-shadow: var(--shadow-card);
    }
  }
  .music-toggle:active { transform: scale(0.94); }
  .music-toggle[data-on='true'] {
    background: var(--accent-rose);
    color: #fff;
    border-color: var(--accent-rose);
  }

  .music-toast {
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    background: var(--ink-primary);
    color: #fff;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-family: var(--font-engraved);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    box-shadow: var(--shadow-card);
  }
</style>

<script>
  import { wedding } from '../data/wedding'

  const audio = document.getElementById('music-audio') as HTMLAudioElement
  const prompt = document.getElementById('music-prompt')!
  const yes = document.getElementById('music-yes')!
  const no = document.getElementById('music-no')!
  const toggle = document.getElementById('music-toggle') as HTMLButtonElement
  const toggleIcon = document.getElementById('music-toggle-icon')!
  const toast = document.getElementById('music-toast')!

  const STORAGE_KEY = 'music_pref'
  type Pref = 'on' | 'off' | 'asked-no'

  audio.volume = 0.4

  function setToggleState(on: boolean) {
    toggle.dataset.on = String(on)
    toggleIcon.textContent = on ? '⏸' : '♪'
    toggle.setAttribute('aria-label', on ? 'Выключить музыку' : 'Включить музыку')
    toggle.hidden = false
  }

  function showToast(text: string) {
    toast.textContent = text
    toast.hidden = false
    window.setTimeout(() => (toast.hidden = true), 2500)
  }

  async function tryPlay() {
    if (!audio.src || audio.src === window.location.href) {
      showToast(wedding.music.placeholderToast)
      return false
    }
    try {
      await audio.play()
      return true
    } catch {
      showToast('Браузер заблокировал автозапуск. Нажмите ♪')
      return false
    }
  }

  function pause() {
    audio.pause()
  }

  yes.addEventListener('click', async () => {
    prompt.hidden = true
    const ok = await tryPlay()
    setToggleState(ok)
    localStorage.setItem(STORAGE_KEY, ok ? ('on' as Pref) : ('off' as Pref))
  })

  no.addEventListener('click', () => {
    prompt.hidden = true
    setToggleState(false)
    localStorage.setItem(STORAGE_KEY, 'asked-no' as Pref)
  })

  toggle.addEventListener('click', async () => {
    if (audio.paused) {
      const ok = await tryPlay()
      if (ok) setToggleState(true)
    } else {
      pause()
      setToggleState(false)
    }
  })

  const pref = localStorage.getItem(STORAGE_KEY) as Pref | null
  if (pref === 'on') {
    // User previously enabled music. Browsers block autoplay without a gesture,
    // so attach a one-shot listener to the next user interaction and try then.
    setToggleState(false)
    const tryOnGesture = async () => {
      const ok = await tryPlay()
      if (ok) setToggleState(true)
      document.removeEventListener('click', tryOnGesture)
      document.removeEventListener('touchstart', tryOnGesture)
    }
    document.addEventListener('click', tryOnGesture, { once: true })
    document.addEventListener('touchstart', tryOnGesture, { once: true })
  } else if (pref === 'asked-no' || pref === 'off') {
    setToggleState(false)
  } else {
    window.setTimeout(() => {
      prompt.hidden = false
    }, wedding.music.autoPromptDelayMs)
  }
</script>
