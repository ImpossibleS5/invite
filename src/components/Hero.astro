---
import { wedding } from '../data/wedding'
const base = import.meta.env.BASE_URL
const initials = `${wedding.couple.bride[0]} & ${wedding.couple.groom[0]}`
---

<section class="hero" id="hero">
  <div class="hero__bg" aria-hidden="true">
    <img src={`${base}decor/hero-bg.svg`} alt="" />
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__monogram" aria-hidden="true">{initials}</div>

  <div class="hero__inner">
    <p class="hero__eyebrow">— Wedding day —</p>

    <h1 class="hero__couple">{wedding.couple.displayName}</h1>

    <div class="hero__rule" aria-hidden="true"></div>

    <p class="hero__lead">
      С радостью приглашаем Вас<br/>на празднование нашей свадьбы
    </p>

    <div class="hero__date">
      <div class="hero__date-weekday">{wedding.date.weekday}</div>
      <div class="hero__date-day">{wedding.date.day}</div>
      <div class="hero__date-month">{wedding.date.month}</div>
      <div class="hero__date-year">{wedding.date.year}</div>
    </div>

    <p class="hero__venue">
      <strong>{wedding.venue.name}</strong><br/>
      {wedding.venue.addressShort}
    </p>

    <p class="hero__hint">Подтвердите присутствие ниже&nbsp;↓</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 80px 24px 60px;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse at center, rgba(255, 252, 245, 0.78) 0%, rgba(253, 249, 240, 0.55) 45%, rgba(253, 249, 240, 0.0) 80%);
  }

  .hero__monogram {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-engraved);
    font-weight: 600;
    font-size: 44vmin;
    color: rgba(162, 142, 95, 0.06);
    letter-spacing: 0.04em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__inner > * {
    opacity: 0;
    transform: translateY(14px);
    filter: blur(6px);
    animation: hero-enter 850ms var(--ease-out) forwards;
  }
  .hero__inner > *:nth-child(1) { animation-delay: 80ms; }
  .hero__inner > *:nth-child(2) { animation-delay: 200ms; }
  .hero__inner > *:nth-child(3) { animation-delay: 320ms; }
  .hero__inner > *:nth-child(4) { animation-delay: 420ms; }
  .hero__inner > *:nth-child(5) { animation-delay: 540ms; }
  .hero__inner > *:nth-child(6) { animation-delay: 680ms; }
  .hero__inner > *:nth-child(7) { animation-delay: 820ms; }

  @keyframes hero-enter {
    to { opacity: 1; transform: none; filter: blur(0); }
  }

  .hero__eyebrow {
    font-family: var(--font-engraved);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--accent-gold-deep);
    margin: 0 0 14px;
    line-height: 1;
  }

  .hero__couple {
    font-family: var(--font-script);
    font-size: 56px;
    font-weight: 400;
    color: var(--ink-primary);
    margin: 0 0 14px;
    line-height: 0.95;
    letter-spacing: 0.005em;
  }
  @media (min-width: 768px) {
    .hero__eyebrow { font-size: 12px; letter-spacing: 0.5em; }
    .hero__couple  { font-size: 84px; }
  }

  .hero__rule {
    width: 48px;
    height: 1px;
    background: var(--accent-gold);
    margin: 6px 0 22px;
    opacity: 0.7;
  }

  .hero__lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-secondary);
    margin: 0 auto 30px;
    max-width: 360px;
    line-height: 1.5;
  }
  @media (min-width: 768px) {
    .hero__lead { font-size: 20px; }
  }

  .hero__date {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-areas:
      'wd day mo'
      'wd day year';
    gap: 0 14px;
    align-items: center;
    justify-content: center;
    width: max-content;
    margin: 0 auto 24px;
    padding: 14px 24px;
    border-top: 1px solid var(--accent-gold);
    border-bottom: 1px solid var(--accent-gold);
    color: var(--ink-primary);
  }
  .hero__date-weekday {
    grid-area: wd;
    font-family: var(--font-engraved);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  .hero__date-day {
    grid-area: day;
    font-family: var(--font-engraved);
    font-size: 60px;
    font-weight: 500;
    line-height: 1;
    color: var(--accent-gold-deep);
    letter-spacing: 0;
  }
  .hero__date-month {
    grid-area: mo;
    font-family: var(--font-engraved);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  .hero__date-year {
    grid-area: year;
    font-family: var(--font-engraved);
    font-size: 10px;
    letter-spacing: 0.32em;
    color: var(--ink-secondary);
  }
  @media (min-width: 768px) {
    .hero__date-day { font-size: 76px; }
    .hero__date-weekday,
    .hero__date-month,
    .hero__date-year { font-size: 11px; }
  }

  .hero__venue {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--ink-secondary);
    margin: 0 0 30px;
    line-height: 1.5;
  }
  .hero__venue strong {
    display: inline-block;
    color: var(--ink-primary);
    font-weight: 500;
    font-size: 18px;
    margin-bottom: 2px;
  }
  @media (min-width: 768px) {
    .hero__venue { font-size: 17px; }
    .hero__venue strong { font-size: 19px; }
  }

  .hero__hint {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-muted);
    margin: 0;
  }
</style>
