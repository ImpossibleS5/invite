---
import { wedding } from '../data/wedding'
---

<section class="rsvp section" id="rsvp">
  <div class="container">
    <h2 class="section-title">Подтвердите присутствие</h2>
    <div class="divider">
      <svg viewBox="0 0 60 12" width="56" height="12" aria-hidden="true">
        <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
          <path d="M30 1 L30 11"/>
          <path d="M30 4 C 24 2 18 2 12 5"/>
          <path d="M30 4 C 36 2 42 2 48 5"/>
        </g>
        <ellipse cx="14" cy="5.5" rx="3" ry="1" transform="rotate(-30 14 5.5)" fill="currentColor"/>
        <ellipse cx="46" cy="5.5" rx="3" ry="1" transform="rotate(30 46 5.5)" fill="currentColor"/>
        <circle cx="30" cy="11" r="1.2" fill="currentColor"/>
      </svg>
    </div>

    <p class="rsvp__lead">
      Пожалуйста, дайте знать, сможете ли вы быть с нами в этот особенный день
    </p>

    <form class="rsvp-form" id="rsvp-form" novalidate>
      <label class="rsvp-form__label" for="rsvp-name">Ваше имя и фамилия</label>
      <input
        type="text"
        id="rsvp-name"
        name="name"
        autocomplete="name"
        class="rsvp-form__input"
        required
      />

      <fieldset class="rsvp-form__radios">
        <legend>Присутствие</legend>
        <label class="rsvp-form__radio">
          <input type="radio" name="attendance" value="yes" />
          <span>{wedding.rsvp.attendanceValues.yes}</span>
        </label>
        <label class="rsvp-form__radio">
          <input type="radio" name="attendance" value="no" />
          <span>{wedding.rsvp.attendanceValues.no}</span>
        </label>
      </fieldset>

      <input
        type="text"
        name="phone_alt"
        id="rsvp-honeypot"
        tabindex="-1"
        autocomplete="off"
        class="rsvp-form__honeypot"
        aria-hidden="true"
      />

      <div class="rsvp-form__notice" id="rsvp-notice" role="status" aria-live="polite" hidden></div>

      <noscript>
        <p class="rsvp-form__noscript">
          Для отправки формы нужно включить JavaScript. Если не получается — напишите нам в&nbsp;мессенджер.
        </p>
      </noscript>

      <button type="submit" class="primary rsvp-form__submit" id="rsvp-submit" disabled>
        Отправить
      </button>
    </form>
  </div>
</section>

<style>
  .rsvp { text-align: center; }
  .rsvp__lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-secondary);
    margin: 0 auto 32px;
    max-width: 360px;
    line-height: 1.5;
  }

  .rsvp-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }
  .rsvp-form__label {
    font-family: var(--font-engraved);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-secondary);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    margin-bottom: -6px;
  }
  .rsvp-form__input {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--accent-gold);
    padding: 11px 0;
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--ink-primary);
    transition: border-color 220ms var(--ease-out);
    width: 100%;
  }
  .rsvp-form__input:focus {
    outline: none;
    border-bottom-color: var(--accent-rose-deep);
    border-bottom-width: 2px;
  }
  .rsvp-form__radios {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rsvp-form__radios legend {
    font-family: var(--font-engraved);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-secondary);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    margin-bottom: 12px;
  }
  .rsvp-form__radio {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-serif);
    font-size: 17px;
    cursor: pointer;
    line-height: 1.4;
  }
  .rsvp-form__radio input[type='radio'] {
    accent-color: var(--accent-rose-deep);
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .rsvp-form__honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  /* Inline notice — replaces the captcha slot. Appears between radios and submit */
  .rsvp-form__notice {
    background: rgba(162, 142, 95, 0.10);
    border: 1px solid var(--accent-gold);
    border-radius: var(--radius-card);
    padding: 14px 16px;
    color: var(--ink-primary);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.4;
    text-align: center;
    transition: opacity 400ms var(--ease-out);
  }
  .rsvp-form__notice[data-kind='error'] {
    background: rgba(201, 122, 122, 0.10);
    border-color: #C97A7A;
    color: #8A4848;
  }

  .rsvp-form__submit {
    margin-top: 8px;
    align-self: stretch;
  }
  .rsvp-form__noscript {
    background: rgba(212, 165, 165, 0.15);
    border: 1px solid var(--accent-rose);
    border-radius: var(--radius-card);
    padding: 12px 14px;
    color: var(--ink-primary);
    font-family: var(--font-serif);
    font-size: 14px;
    margin: 0;
  }
</style>

<script>
  import { wedding } from '../data/wedding'
  import { isFormReady } from '../scripts/rsvp'

  const form = document.getElementById('rsvp-form') as HTMLFormElement
  const submit = document.getElementById('rsvp-submit') as HTMLButtonElement
  const nameInput = document.getElementById('rsvp-name') as HTMLInputElement
  const honeypot = document.getElementById('rsvp-honeypot') as HTMLInputElement
  const notice = document.getElementById('rsvp-notice')!
  const radios = form.querySelectorAll<HTMLInputElement>('input[name="attendance"]')

  const validate = () => {
    const checked = [...radios].find((r) => r.checked)
    submit.disabled = !isFormReady(nameInput.value, checked?.value ?? null)
  }

  nameInput.addEventListener('input', validate)
  radios.forEach((r) => r.addEventListener('change', validate))

  let hideTimer: number | null = null
  function showNotice(text: string, kind: 'success' | 'error' = 'success') {
    notice.textContent = text
    notice.dataset.kind = kind
    notice.hidden = false
    if (hideTimer !== null) window.clearTimeout(hideTimer)
    if (kind === 'success') {
      hideTimer = window.setTimeout(() => {
        notice.hidden = true
        hideTimer = null
      }, 5000)
    }
  }

  async function sendWithRetry(body: URLSearchParams): Promise<void> {
    try {
      await fetch(wedding.rsvp.formActionUrl, { method: 'POST', mode: 'no-cors', body })
    } catch {
      await new Promise((r) => window.setTimeout(r, 2000))
      await fetch(wedding.rsvp.formActionUrl, { method: 'POST', mode: 'no-cors', body })
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (honeypot.value.trim() !== '') {
      // bot — fake success, do nothing
      showNotice(wedding.rsvp.successMessage)
      form.reset()
      validate()
      return
    }
    const attendance = [...radios].find((r) => r.checked)?.value
    if (!attendance) return

    submit.disabled = true
    try {
      const body = new URLSearchParams()
      body.append(wedding.rsvp.fields.name, nameInput.value.trim())
      body.append(
        wedding.rsvp.fields.attendance,
        attendance === 'yes'
          ? wedding.rsvp.attendanceValues.yes
          : wedding.rsvp.attendanceValues.no
      )

      await sendWithRetry(body)

      const msg =
        attendance === 'yes' ? wedding.rsvp.successMessage : wedding.rsvp.declineMessage
      showNotice(msg)
      form.reset()
      validate()
    } catch {
      showNotice(wedding.rsvp.errorMessage, 'error')
      validate()
    }
  })

  validate()
</script>
