---
const menu = [
  { href: '#letter', label: 'Приглашение' },
  { href: '#program', label: 'Программа дня' },
  { href: '#map', label: 'Карта' },
  { href: '#dresscode', label: 'Дресс-код' },
  { href: '#rsvp', label: 'Подтверждение' },
]
---

<header class="header" id="header">
  <div class="header__inner">
    <a class="header__brand" href="#hero">ПРИГЛАШЕНИЕ</a>

    <button class="header__burger" id="header-burger" aria-label="Открыть меню" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<button class="menu__backdrop" id="menu-backdrop" aria-hidden="true" tabindex="-1"></button>

<nav class="menu" id="menu" aria-hidden="true">
  <button class="menu__close" id="menu-close" aria-label="Закрыть меню">×</button>
  <p class="menu__heading" aria-hidden="true">Меню</p>
  <ul>
    {menu.map((m) => (
      <li><a href={m.href} class="menu__link">{m.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(253, 249, 240, 0.94);
    border-bottom: 1px solid var(--line-soft);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
  }
  .header__brand {
    font-family: var(--font-engraved);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.42em;
    color: var(--ink-primary);
    border-bottom: none;
    text-transform: uppercase;
  }
  .header__burger {
    background: transparent;
    border: none;
    width: 32px;
    height: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    padding: 0;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink-primary);
    margin: 0 auto;
    transition: transform 200ms ease-out, opacity 200ms ease-out;
  }

  /* Backdrop: fades in behind menu when open */
  .menu__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(45, 38, 32, 0.55);
    backdrop-filter: blur(2px);
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 280ms var(--ease-out);
    z-index: 55;
  }
  .menu__backdrop[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Mobile: full-screen sheet sliding from top */
  .menu {
    position: fixed;
    inset: 0;
    background: var(--bg-paper);
    transform: translateY(-100%);
    transition: transform 380ms var(--ease-drawer);
    z-index: 60;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
  }
  .menu[data-open='true'] { transform: none; }

  /* Desktop: side panel sliding from right */
  @media (min-width: 768px) {
    .menu {
      inset: 0 0 0 auto;
      width: 340px;
      background: linear-gradient(180deg, #FFFFFF 0%, #FBF4E8 100%);
      transform: translateX(100%);
      box-shadow: -24px 0 80px rgba(45, 38, 32, 0.30);
      border-left: 3px solid var(--accent-gold);
      align-items: flex-start;
      justify-content: flex-start;
      padding: 96px 40px 40px;
      transition: transform 380ms var(--ease-drawer);
    }
  }

  .menu__close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--line-soft);
    border-radius: 50%;
    font-size: 24px;
    color: var(--ink-primary);
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 180ms var(--ease-out), border-color 180ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .menu__close:hover {
      background: var(--bg-soft);
      border-color: var(--accent-gold);
    }
  }

  .menu__heading {
    display: none;
    font-family: var(--font-engraved);
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--accent-gold);
    margin: 0 0 24px;
  }
  @media (min-width: 768px) {
    .menu__heading { display: block; }
  }

  .menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
    width: 100%;
  }
  @media (min-width: 768px) {
    .menu ul { text-align: left; }
  }
  .menu li + li {
    border-top: 1px solid var(--line-soft);
  }
  .menu__link {
    display: block;
    padding: 18px 0;
    font-family: var(--font-engraved);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-primary);
    border-bottom: none;
    transition: color 180ms var(--ease-out), padding-left 220ms var(--ease-out);
  }
  @media (min-width: 768px) {
    .menu__link { font-size: 13px; }
  }
  @media (hover: hover) and (pointer: fine) {
    .menu__link:hover {
      color: var(--accent-gold-deep);
    }
    @media (min-width: 768px) {
      .menu__link:hover { padding-left: 6px; }
    }
  }
</style>

<script>
  const burger = document.getElementById('header-burger')
  const menu = document.getElementById('menu')
  const close = document.getElementById('menu-close')
  const backdrop = document.getElementById('menu-backdrop')

  function setOpen(open: boolean) {
    if (!menu || !burger) return
    menu.dataset.open = String(open)
    menu.setAttribute('aria-hidden', String(!open))
    burger.setAttribute('aria-expanded', String(open))
    if (backdrop) {
      backdrop.dataset.open = String(open)
      backdrop.setAttribute('aria-hidden', String(!open))
    }
    document.body.style.overflow = open ? 'hidden' : ''
    document.body.classList.toggle('menu-open', open)
  }

  burger?.addEventListener('click', () => setOpen(true))
  close?.addEventListener('click', () => setOpen(false))
  backdrop?.addEventListener('click', () => setOpen(false))
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  )
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.dataset.open === 'true') setOpen(false)
  })
</script>
